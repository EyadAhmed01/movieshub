generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  name           String?
  /// UI prefs: { showBadgesOnHome, chatSpoilerMode, … }
  preferences    Json?
  /// Cached AI taste + monthly persona; keys tasteWeekKey, monthKey, taste, month
  insightsCache  Json?
  createdAt      DateTime        @default(now())
  movies         MovieEntry[]
  series         SeriesEntry[]
  watchlistItems WatchlistItem[]
}

model WatchlistItem {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tmdbId           Int
  mediaType        String
  title            String
  year             Int?
  yearsLabel       String?
  posterPath       String?
  overview         String?
  voteAverage      Float?
  runtimeMinutes   Int?
  episodeRuntimeMinutes Int?
  genres           Json?
  cast             Json?
  createdAt        DateTime @default(now())

  @@unique([userId, tmdbId, mediaType])
  @@index([userId])
}

model MovieEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  year         Int
  tmdbId       Int?
  posterPath   String?
  overview     String?
  voteAverage  Float?
  userRating   Int?
  runtimeMinutes Int?
  genres       Json?
  cast         Json?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model SeriesEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  years        String
  eps          Int?
  tmdbId       Int?
  posterPath   String?
  overview     String?
  voteAverage  Float?
  userRating   Int?
  episodeRuntimeMinutes Int?
  genres       Json?
  cast         Json?
  createdAt    DateTime @default(now())

  @@index([userId])
}
