# PostgreSQL — local Docker: docker compose up -d
# Then: npx prisma db push && npm run db:seed
DATABASE_URL="postgresql://movie:movie@localhost:5432/movie?schema=public"

# Public URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Free key: https://www.themoviedb.org/settings/api (optional; enriches search + posters + TMDB ratings)
TMDB_API_KEY=""

# Reel Llama chat — default uses Groq’s Llama API (free tier): https://console.groq.com
# Or use local Ollama: LLM_PROVIDER=ollama and run `ollama pull llama3.2`
LLM_PROVIDER="groq"
GROQ_API_KEY=""
GROQ_MODEL="llama-3.1-8b-instant"
# OLLAMA_URL="http://127.0.0.1:11434"
# OLLAMA_MODEL="llama3.2"
# Optional cast fallback: on Analytics, check “Also use AI for cast” when refreshing (uses same Groq/Ollama as chat).

# For You: log RecImpression rows + train ranker (see scripts/). Set REC_IMPRESSIONS=0 to disable DB writes.
# REC_IMPRESSIONS=1
# Optional path to ranker JSON (default: ./data/ranker_weights.json)
# RANKER_WEIGHTS_PATH=

# Optional: demo account created by npm run db:seed
# SEED_DEMO_EMAIL=demo@demo.local
# SEED_DEMO_PASSWORD=demo-demo
