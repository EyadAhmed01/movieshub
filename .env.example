# PostgreSQL — local Docker: docker compose up -d
# Then: npx prisma db push && npm run db:seed
DATABASE_URL="postgresql://movie:movie@localhost:5432/movie?schema=public"

# Public URL of the app (no trailing slash)
NEXTAUTH_URL="http://localhost:3000"

# openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Free key: https://www.themoviedb.org/settings/api (optional; enriches search + posters + TMDB ratings)
TMDB_API_KEY=""

# Optional: demo account created by npm run db:seed
# SEED_DEMO_EMAIL=demo@demo.local
# SEED_DEMO_PASSWORD=demo-demo
